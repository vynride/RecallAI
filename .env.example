# ─── Auth (Auth.js / NextAuth v5) ───────────────────────────────────────────
# Secret used to sign JWTs. Generate with: openssl rand -base64 32
# AUTH_SECRET is read by the Next.js client; NEXTAUTH_SECRET is the same value
# read by the FastAPI backend to verify the same JWTs.
AUTH_SECRET=
NEXTAUTH_SECRET=
# Base URL of the Next.js app — required for Auth.js to build callback URLs
AUTH_URL=http://localhost:3000

# Google OAuth app — https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth app — https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Backend ─────────────────────────────────────────────────────────────────
# Random 32-byte secret used to encrypt per-user stored Gemini API keys (BYOK).
# Generate with: openssl rand -base64 32
GEMINI_KEY_PEPPER=

# Comma-separated CORS origins the FastAPI backend will accept requests from.
ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=recallai
POSTGRES_PASSWORD=recallai
POSTGRES_DB=recallai

# ─── Storage ──────────────────────────────────────────────────────────────────
# Absolute host path for Docker bind-mount volumes.
# Must be on a Linux-native FS (ext4/btrfs/xfs) — NTFS/FUSE breaks
# Postgres/Redis chmod during container init.
RECALLAI_DATA_DIR=/home/user/recallai-data

# ─── Celery (optional overrides) ──────────────────────────────────────────────
# Number of concurrent Celery worker processes (default: 4)
# CELERY_CONCURRENCY=4

# ─── Analytics — Umami (optional) ────────────────────────────────────────────
# Self-hosted Umami instance bundled in docker-compose.yml.
# Leave blank to disable tracking.
UMAMI_APP_SECRET=
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_DB_NAME=umami
# Paste the Website ID from Umami → Settings → Websites after first boot.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# URL where the umami.js script is served (e.g. http://localhost:3001/script.js)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
